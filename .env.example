# zee6do server environment variables
# Copy to .env and fill in values

# MongoDB
ZEE6DO_MONGODB_URI=mongodb://localhost:27017
ZEE6DO_MONGODB_DATABASE=zee6do
ZEE6DO_MONGODB_MAX_POOL_SIZE=100
ZEE6DO_MONGODB_TIMEOUT=30s

# Server
ZEE6DO_SERVER_GRPC_PORT=50051
ZEE6DO_SERVER_ENVIRONMENT=development

# Logging
ZEE6DO_LOGGING_LEVEL=debug

# Shutdown
ZEE6DO_SHUTDOWN_GRACE_PERIOD=30s
ZEE6DO_SHUTDOWN_DRAIN_INTERVAL=10s
